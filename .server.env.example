# Copy this file to /home/ubuntu/sgcc-trust-data-space/.server.env on the server.
# Every placeholder below must be replaced before first start.
# Suggested secret generation:
#   openssl rand -hex 32

SGCC_PLATFORM_PORT=8088

SGCC_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/sgcc_platform?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
SGCC_MYSQL_USERNAME=__REPLACE_WITH_MYSQL_USERNAME__
SGCC_MYSQL_PASSWORD=__REPLACE_WITH_MYSQL_PASSWORD__

SGCC_REDIS_HOST=127.0.0.1
SGCC_REDIS_PORT=6379
SGCC_REDIS_PASSWORD=__REPLACE_WITH_REDIS_PASSWORD__

SGCC_POSTGRES_URL=jdbc:postgresql://127.0.0.1:5432/sgcc_meta
SGCC_POSTGRES_USERNAME=__REPLACE_WITH_POSTGRES_USERNAME__
SGCC_POSTGRES_PASSWORD=__REPLACE_WITH_POSTGRES_PASSWORD__

SGCC_IPFS_API_URL=http://127.0.0.1:5001
SGCC_IPFS_GATEWAY_URL=http://127.0.0.1:8080
SGCC_PRIVACY_BASE_URL=http://127.0.0.1:8010
SGCC_PRIVACY_MASTER_KEY_HEX=__REPLACE_WITH_64_HEX_CHARS__

SGCC_CHAIN_GROUP_ID=group0
SGCC_CHAIN_SERVICE_USER_NAME=__REPLACE_WITH_CHAIN_SERVICE_USERNAME__
SGCC_CHAIN_SERVICE_PRIVATE_KEY=__REPLACE_WITH_CHAIN_SERVICE_PRIVATE_KEY__
SGCC_CHAIN_SERVICE_ADDRESS=__REPLACE_WITH_CHAIN_SERVICE_ADDRESS__
SGCC_WEBASE_QINGDAO_BASE_URL=http://127.0.0.1:5100/WeBASE-Front
SGCC_WEBASE_WEIFANG_BASE_URL=http://127.0.0.1:5101/WeBASE-Front
SGCC_WEBASE_RELAY_BASE_URL=http://127.0.0.1:5102/WeBASE-Front
